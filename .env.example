ENVIRONMENT=development
DEBUG=false

# OpenAI
OPENAI_API_KEY=sk-test-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# Pinecone
PINECONE_API_KEY=test-pinecone-key
PINECONE_ENVIRONMENT=test-environment
PINECONE_INDEX_NAME=orchestra-knowledge

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=

# Postgres (used by Temporal container and tests)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orchestra
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=orchestra

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=orchestra-tasks

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
# Orchestra AI Agent System - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Orchestra
VERSION=0.1.0
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# =============================================================================
# OPENAI CONFIGURATION (REQUIRED)
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# =============================================================================
# PINECONE CONFIGURATION (REQUIRED)
# =============================================================================
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=orchestra-knowledge
PINECONE_DIMENSION=3072

# =============================================================================
# TEMPORAL CONFIGURATION
# =============================================================================
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=orchestra-tasks

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orchestra
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=your-secure-database-password

# =============================================================================
# GITHUB INTEGRATION (OPTIONAL)
# =============================================================================
# Generate a personal access token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_ORG=your-organization
GITHUB_REPO=your-repository

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
SECURITY_ENABLE_AUDIT_LOGGING=true
SECURITY_MAX_FILE_SIZE=10000000  # 10MB
SECURITY_ENABLE_CODE_SCANNING=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_JSON_FORMAT=false
LOG_ENABLE_AUDIT=true

# =============================================================================
# DEVELOPMENT SETTINGS (Development Environment Only)
# =============================================================================
# These settings are only used in development mode

# Enable additional debugging
DEV_ENABLE_DEBUG_LOGGING=true
DEV_MOCK_EXTERNAL_APIS=false
DEV_SKIP_SECURITY_VALIDATION=false

# =============================================================================
# PRODUCTION SETTINGS (Production Environment Only)
# =============================================================================
# These settings are only used in production mode

# Security enhancements for production
PROD_FORCE_HTTPS=true
PROD_ENABLE_RATE_LIMITING=true
PROD_MAX_REQUESTS_PER_MINUTE=100

# =============================================================================
# ADVANCED CONFIGURATION (Optional)
# =============================================================================

# Custom model configurations
# CUSTOM_MODEL_ENDPOINT=https://your-custom-endpoint.com
# CUSTOM_MODEL_API_KEY=your-custom-model-key

# Monitoring and observability
# MONITORING_ENDPOINT=https://your-monitoring-service.com
# MONITORING_API_KEY=your-monitoring-key

# External service timeouts (in seconds)
OPENAI_TIMEOUT=30
PINECONE_TIMEOUT=10
GITHUB_TIMEOUT=15
TEMPORAL_TIMEOUT=30

# Retry configurations
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2

# =============================================================================
# NOTES AND DOCUMENTATION
# =============================================================================

# Required Environment Variables:
# - OPENAI_API_KEY: Required for all AI operations
# - PINECONE_API_KEY: Required for vector database operations
# - PINECONE_ENVIRONMENT: Required for Pinecone connection
# - POSTGRES_PASSWORD: Required for database connection

# Optional Environment Variables:
# - GITHUB_TOKEN: Only required if using GitHub integration features
# - All other variables have sensible defaults

# Security Notes:
# 1. Never commit this file with real values to version control
# 2. Use strong, unique passwords for database connections
# 3. Regularly rotate API keys and tokens
# 4. Consider using a secrets management service for production

# Development Setup:
# 1. Copy this file to .env
# 2. Fill in your API keys and credentials
# 3. Run: poetry install
# 4. Run: docker-compose up -d
# 5. Run: poetry run orchestra --help

# Production Deployment:
# 1. Use environment-specific configuration management
# 2. Enable all security features
# 3. Use secure secrets storage
# 4. Enable monitoring and logging
# 5. Review security settings regularly
