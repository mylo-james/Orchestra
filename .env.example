# Orchestra AI Agent System - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file with real secrets!

# ============================================================================
# AI SERVICE CONFIGURATION
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# ============================================================================
# WORKFLOW ORCHESTRATION
# ============================================================================

# Temporal Configuration
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=orchestra-ai-tasks
TEMPORAL_CLOUD_API_KEY=your_temporal_cloud_api_key_here
TEMPORAL_CLOUD_NAMESPACE=your_temporal_namespace_here

# ============================================================================
# VECTOR DATABASE
# ============================================================================

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=orchestra-knowledge
PINECONE_DIMENSION=1536

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_APP_ID=your_github_app_id_here
GITHUB_PRIVATE_KEY_PATH=path_to_github_private_key.pem

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Configuration (for metadata storage)
DATABASE_URL=postgresql://username:password@localhost:5432/orchestra_ai
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=orchestra_ai
DATABASE_USER=orchestra_user
DATABASE_PASSWORD=your_secure_database_password

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT Configuration
JWT_SECRET_KEY=your_very_secure_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption Keys
ENCRYPTION_KEY=your_32_byte_encryption_key_here
SALT=your_secure_salt_here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Frontend Configuration (if applicable)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=logs/orchestra.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Metrics & Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# Tracing (if using distributed tracing)
JAEGER_ENDPOINT=http://localhost:14268/api/traces
TRACE_SAMPLING_RATE=0.1

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================

# Development Tools
ENABLE_DEBUG_TOOLBAR=true
ENABLE_PROFILING=false
MOCK_EXTERNAL_APIS=false

# Test Configuration
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/orchestra_test
TEST_OPENAI_API_KEY=test_key_for_mocking
TEST_GITHUB_TOKEN=test_token_for_mocking

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# AWS Configuration (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=orchestra-ai-storage

# Container Configuration
CONTAINER_REGISTRY=your_container_registry_url
CONTAINER_TAG=latest

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# AI Safety Features
ENABLE_PROMPT_INJECTION_DETECTION=true
ENABLE_CODE_SECURITY_SCANNING=true
ENABLE_OUTPUT_VALIDATION=true
ENABLE_RATE_LIMITING=true

# Agent Features
ENABLE_AGENT_MONITORING=true
ENABLE_AGENT_HANDOFF_LOGGING=true
ENABLE_KNOWLEDGE_BASE_SYNC=true

# Development Features
ENABLE_HOT_RELOAD=true
ENABLE_MOCK_SERVICES=false

# ============================================================================
# NOTES
# ============================================================================

# Security Notes:
# - Never commit the actual .env file
# - Use strong, unique passwords and keys
# - Rotate secrets regularly
# - Use environment-specific values for different deployments
# - Consider using a secrets management service for production

# AI Safety Notes:
# - Keep API keys secure and monitor usage
# - Enable all safety features in production
# - Regularly audit AI agent behavior
# - Monitor for unusual patterns or usage spikes

# Performance Notes:
# - Adjust rate limits based on your usage patterns
# - Monitor database performance and scale as needed
# - Consider caching strategies for high-traffic endpoints