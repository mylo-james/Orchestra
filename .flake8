[flake8]
# Orchestra AI Agent System - Flake8 Configuration

# Basic Configuration
max-line-length = 88
max-complexity = 10
max-doc-length = 88

# File patterns
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg,
    build,
    dist,
    .tox,
    migrations,
    .mypy_cache,
    .pytest_cache

# Error codes to ignore (compatible with Black)
ignore = 
    # Line length (handled by Black)
    E501,
    # Line break before binary operator (Black handles this)
    W503,
    # Whitespace before ':' (Black handles this)
    E203,
    # Multiple statements on one line (sometimes needed)
    E701,

# Error codes to always check
select = 
    # Pyflakes errors
    F,
    # PEP 8 errors
    E,
    # PEP 8 warnings  
    W,
    # McCabe complexity
    C90,
    # Docstring conventions
    D,
    # Bugbear warnings
    B,
    # Comprehension improvements
    C4,
    # Simplify suggestions
    SIM,

# Docstring requirements
docstring-convention = google
require-plugins = 
    flake8-docstrings,
    flake8-bugbear,
    flake8-comprehensions,
    flake8-simplify

# Per-file ignores
per-file-ignores = 
    # Tests don't need docstrings for every function
    tests/*:D100,D101,D102,D103,D104,D105,D106,D107
    # __init__.py files don't need docstrings
    __init__.py:D104
    # Migration files have different standards
    migrations/*:D100,D101,D102,D103,D104,D105,D106,D107,E501
    # CLI files can have longer lines for help text
    src/cli/*:E501
    # Configuration files
    src/config/*:D100,D101,D102,D103

# AI Agent Specific Rules
# These are custom rules for AI agent development

# Agent tool functions must have comprehensive docstrings
# Format: Google style with Parameters, Returns, Raises, Security sections

# Example of compliant agent tool docstring:
# def process_user_request(request: str, context: Dict[str, Any]) -> AgentResponse:
#     """Process user request with security validation.
#     
#     This tool function processes user requests while maintaining security
#     guardrails and proper input validation.
#     
#     Parameters:
#         request: The user request string (validated and sanitized)
#         context: Additional context for processing
#         
#     Returns:
#         AgentResponse: Structured response with validation results
#         
#     Raises:
#         ValidationError: If input validation fails
#         SecurityError: If security checks fail
#         
#     Security:
#         - Input is validated for prompt injection
#         - Output is scanned for dangerous patterns
#         - All operations are logged for audit
#     """